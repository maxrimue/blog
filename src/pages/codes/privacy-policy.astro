---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Codes — Privacy Policy">
  <article class="mx-auto max-w-2xl">
    <h1 class="text-3xl font-bold mb-2">Privacy Policy</h1>
    <p class="text-sm text-text-muted mb-10">Codes for Mac</p>

    <div class="space-y-8 text-text-muted leading-relaxed">
      <section>
        <h2 class="text-base font-semibold text-text mb-2">No data collection</h2>
        <p>
          Codes does not collect, store, transmit, or share any personal data or
          usage information. The app operates entirely on your device and never
          makes any network requests.
        </p>
      </section>

      <section>
        <h2 class="text-base font-semibold text-text mb-2">No third-party services</h2>
        <p>
          Codes does not integrate with any analytics, crash reporting, or
          advertising services. No third party ever receives data of any kind
          as a result of using the app.
        </p>
      </section>

      <section>
        <h2 class="text-base font-semibold text-text mb-2">Local storage</h2>
        <p>
          Any data you create or configure within Codes stays exclusively on
          your Mac. It is never uploaded or synced to external servers.
        </p>
      </section>

      <section>
        <h2 class="text-base font-semibold text-text mb-2">Contact</h2>
        <p>
          If you have questions about this privacy policy, feel free to reach
          out at{" "}
          <a
            href="mailto:codes@maxrimue.dev"
            class="text-accent hover:text-accent-hover transition-colors"
          >codes@maxrimue.dev</a>.
        </p>
      </section>
    </div>
  </article>
</Layout>
