---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Codes — Support">
  <article class="mx-auto max-w-2xl">
    <h1 class="text-3xl font-bold mb-2">Support</h1>
    <p class="text-sm text-text-muted mb-10">Codes for Mac</p>

    <div class="space-y-8 text-text-muted leading-relaxed">
      <section>
        <h2 class="text-base font-semibold text-text mb-2">Get in touch</h2>
        <p>
          For any questions, feedback, or bug reports regarding Codes, send an
          email to{" "}
          <a
            href="mailto:codes@maxrimue.dev"
            class="text-accent hover:text-accent-hover transition-colors"
          >codes@maxrimue.dev</a>.
        </p>
      </section>

      <section>
        <h2 class="text-base font-semibold text-text mb-2">What to include</h2>
        <p>
          A brief description of your question or issue, along with the macOS
          version you are running, is usually enough to get started. Responses
          are typically sent within a few business days.
        </p>
      </section>
    </div>
  </article>
</Layout>
